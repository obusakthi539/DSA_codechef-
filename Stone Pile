import java.util.*;
public class Main{
    public static void main (String[] args) {
        Scanner sc=new Scanner(System.in);
        int t=sc.nextInt();
        while(t-->0){
            int n=sc.nextInt();
            Queue<Integer> q=new LinkeddList<>();
            for(int i=0;i<n;i++){
                q.add(sc.nextInt());
            }
            boolean aman=true;
            int player=-1;
            while(q.size()>1){
                if(aman){
                    q.add(q.poll());
                    q.poll();
                    player=1;
                } else{
                    q.add(q.poll());
                    q.add(q.poll());
                    q.poll();
                    player=0;
                }
                amam=!aman;
            }System.out.println(player+" "+q.peek());
        }
    }
}

