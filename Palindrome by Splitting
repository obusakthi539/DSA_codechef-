import java.util.*;
public class Main{
    public static void main (String[] args) {
        Scanner sc=new Scanner(System.in);
        int t=sc.nextInt();
        while(t-->0){
            int n=sc.nextInt();
            Deque<Integer> dq=new ArrayDeque<>();
            for(int i=0;i<n;i++){
                dq.addLast(sc.nextInt());
            } 
            int op=0;
            while(dq.size()>1) {
               int l=dq.pollFirst();
               int r=dq.pollLast();
                if(l==r){
                    continue;
                }else if(l<r){
                    dq.addLast(r-l);
                    op++;
                }else {
                    dq.addFirst(l-r);
                    op++;
                } } System.out.println(op);
        }
        
    }
}








